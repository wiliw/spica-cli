{
  "name": "spica-cli",
  "version": "1.0.0",
  "type": "module",
  "description": "AI coding agent CLI with three-step workflow",
  "main": "dist/index.js",
  "bin": {
    "spica": "bin/spica"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "npm run build:cli",
    "build:cli": "PWD=$(pwd) && cat > bin/spica << EOF\n#!/usr/bin/env -S npx tsx\nimport('${PWD}/src/index.ts');\nEOF\nchmod +x bin/spica",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "lint:strict": "eslint src/**/*.ts --max-warnings 0"
  },
  "keywords": [
    "ai",
    "cli",
    "agent",
    "mvp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.0",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "execa": "^9.1.0",
    "fast-glob": "^3.3.3",
    "fs-extra": "^11.2.0",
    "glob": "^13.0.6",
    "node-pty": "^1.1.0",
    "npm-run-path": "^6.0.0",
    "openai": "^4.52.0",
    "ora": "^8.0.1",
    "prompts": "^2.4.2",
    "simple-git": "^3.25.0",
    "unicorn-magic": "^0.4.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.12.12",
    "@types/prompts": "^2.4.9",
    "tsx": "^4.21.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
