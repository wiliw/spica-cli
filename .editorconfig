# EditorConfig - 统一不同编辑器的格式化规则
# https://editorconfig.org

root = true

# 所有文件的默认规则
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# TypeScript/JavaScript 文件
[*.ts, *.js]
indent_size = 2

# JSON 文件
[*.json]
indent_size = 2

# Markdown 文件 - 不删除尾部空格（用于换行）
[*.md]
trim_trailing_whitespace = false

# YAML 文件
[*.{yml, yaml}]
indent_size = 2

# Makefile 必须用 tab
[Makefile]
indent_style = tab